GET ${env.BASE_URL}/players/$Unnamed_1{ PLAYER_ID }/quests/evolution
Authorization: Bearer ${ AUTH_TOKEN }

$RETRY{
    local status = sinq.responses[3].body.status
    if status == "calculating_stats" then
        return 10 -- sleep 10ms and retry
    end
    return -1
}

$ASSERT{
    if sinq.responses[3].body.status ~= "complete" then
        sinq.test.fail("Class evolution never finished")
        print(sinq.responses[3].bodyRaw)
    end
}
