$PRE{
    -- Validate that the secret was actually passed via the CLI
    if not secrets.OMNI_COIN_API_KEY then
        error("Missing OMNI_COIN_API_KEY in secrets file")
    end
}
POST ${env.BASE_URL}/shop/premium/purchase
Authorization: Bearer ${ secrets.OMNI_COIN_API_KEY }
Content-Type: application/json

{
    "item": "resurrection_scroll"
}

$ASSERT{
    if sinq.responses[1].code ~= 200 then
        sinq.test.fail("Premium purchase failed")
    end
}
