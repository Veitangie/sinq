POST ${env.BASE_URL}/system/login
Content-Type: application/json

{
    "user": "player_one",
    "password": "hunter2"
}

$ASSERT{ 
  sinq.assert.code(200, "System login failed") 
  sinq.assert.isTrue(type(res.json().token) == "string", "Returned token is not string")
}

$POST{ AUTH_TOKEN = res.json().token }
