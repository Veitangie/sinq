$PRE{
    if not AUTH_TOKEN then error("Token missing") end
}
POST ${env.BASE_URL}/players
Authorization: Bearer ${ AUTH_TOKEN }
Content-Type: application/json

{
    "name": "Scyth",
    "class": "Spellsword"
}

$ASSERT{ sinq.assert.code(201, "Failed to create character") }

$POST{ PLAYER_ID = res.json().id }
