$PRE{
    if not PLAYER_ID then error("Player ID missing") end
}
POST ${env.BASE_URL}/trade/buy
Authorization: Bearer ${ AUTH_TOKEN }
Content-Type: application/json

{
    "player_id": ${PLAYER_ID},
    "item": "health_potion"
}

$ASSERT{
    if sinq.responses[3].code ~= 200 then
        sinq.test.fail("Failed to buy item")
    end
}
